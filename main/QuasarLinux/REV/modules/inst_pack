#!/usr/bin/env bash
set -eo pipefail
# set -x # Если нужно дебажить — раскомментируй

# --- Инициализация локализации (gettext) ---
SYSTEM_LANG=${LANG:0:5}
export TEXTDOMAIN="installer"
export TEXTDOMAINDIR="/usr/local/sdk/global/locale"

if ! command -v gettext &> /dev/null; then
    _() { echo "$1"; }
else
    _() { gettext -s "$1"; }
fi
# ------------------------------------------

SRC="/installer"
MNT="/mnt"
USERLAND="/installer/modules/userland"

# Монтирование
mount_systems() {
    echo "$(_ "[*] Mounting file systems...")"
    mountpoint -q "$MNT/proc" || mount --types proc /proc "$MNT/proc"
    mountpoint -q "$MNT/sys" || mount --rbind /sys "$MNT/sys"
    mountpoint -q "$MNT/dev" || mount --rbind /dev "$MNT/dev"
    mountpoint -q "$MNT/run" || mount --rbind /run "$MNT/run"
}

# Функция выбора профиля
select_profile() {
    local profiles_dir="$SRC/profiles"
    local options=()
    local count=0

    command -v dialog >/dev/null 2>&1 || { echo "$(_ "[ERROR] dialog not found")" >&2; return 1; }

    for conf in "$profiles_dir"/*/main.conf; do
        [ -f "$conf" ] || continue
        local dir="${conf%/*}"
        local name="${dir##*/}"
        options+=("$name" "$(_ "Profile:") $name")
        ((count++))
    done

    if [ $count -eq 0 ]; then
        echo "$(_ "[ERROR] Profiles not found in") $profiles_dir" >&2
        return 1
    fi

    dialog --menu "$(_ "Select installation profile")" 15 50 10 "${options[@]}" 3>&1 1>&2 2>&3 3>&-
    return $?
}

# Логика установки (выполняется внутри chroot)
run_install() {
    local profile="$1"
    local config_file="$SRC/profiles/$profile/main.conf"
    local USERLAND="$SRC/modules/userland"

    if [ ! -f "$config_file" ]; then
        echo "$(_ "[ERROR] Config not found:") $config_file"
        exit 1
    fi

    set -a
    source "$config_file"
    set +a

    echo "$(_ "[*] Loaded profile:") $profile"

    # Обновление баз внутри chroot
    chroot /mnt pacman -Syy --noconfirm

    # Установка пакетов
    [ -n "${desktop:-}" ] && "$USERLAND"/de_install "$desktop" || true
    [ -n "${audio:-}" ] && "$USERLAND"/audio_install "$audio" || true
    [ -n "${office:-}" ] && "$USERLAND"/office_install "$office" || true
    [ -n "${browser:-}" ] && "$USERLAND"/browser_install "$browser" || true
    [ -n "${wine:-}" ] && "$USERLAND"/wine_install "$wine"

    # Кастомные пакеты
    if [ -n "${custom_package:-}" ]; then
        chroot /mnt pacman -S --noconfirm ${custom_package} || true
    fi
    "run_scripts" || true
}

main() {
    mount_systems

    profile=$(select_profile) || {
        echo "$(_ "[ERROR] Profile selection cancelled or failed.")"
        exit 1
    }

    echo "$(_ "[*] Starting installation in chroot...")"
    run_install "$profile"

    echo "$(_ "[*] Installation completed.")"
}

if [ "${1:-}" == "run_install" ]; then
    run_install "$2"
else
    main
fi
