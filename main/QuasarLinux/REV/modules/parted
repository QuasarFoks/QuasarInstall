#!/usr/bin/env bash
set -euo pipefail

# --- Настройка локализации (как в прошлый раз) ---
SYSTEM_LANG=${LANG:0:5}
SUPPORTED_LANGS=("de_DE" "en_US" "es_ES" "fr_FR" "it_IT" "ja_JP" "pt_BR" "ru_RU" "tr_TR" "zh_CN")

LANG_FOUND=0
for lang in "${SUPPORTED_LANGS[@]}"; do
    if [ "$SYSTEM_LANG" = "$lang" ]; then
        LANG_FOUND=1
        break
    fi
done

[ $LANG_FOUND -eq 0 ] && export LANG="en_US.UTF-8" || export LANG="$SYSTEM_LANG.UTF-8"

export TEXTDOMAIN="installer"
export TEXTDOMAINDIR="/usr/local/sdk/global/locale"

if ! command -v gettext &> /dev/null; then
    _() { echo "$1"; }
else
    _() { gettext -s "$1"; }
fi
# -----------------------------------------------

UEFI_MODE=0
export LUKS_MODE=0
[ -d /sys/firmware/efi ] && UEFI_MODE=1

clear
echo "$(_ "Select disk:")"
lsblk -d -o NAME,SIZE,MODEL,TYPE

# Ввод диска
read -p "$(_ "Enter disk name (e.g. sda): ")" DISK
export DISK="/dev/$DISK"
if [ ! -e "$DISK" ]; then
    printf "$(_ "Error: disk %s not found")\n" "$DISK"
    exit 1
fi

old_os_backap() {
    fdisk -l "$DISK" | grep "^/dev"
    read -p "$(_ "Enter ROOT partition (e.g. sda2): ")" ROOT_PART
    local ROOT_PART="/dev/$ROOT_PART"
    mount "$ROOT_PART" /mnt

    if [ $UEFI_MODE -eq 1 ]; then
        read -p "$(_ "Enter EFI partition: ")" BOOT_PART
        echo "$(_ "Formatting EFI...")"
        local BOOT_PART="/dev/$BOOT_PART"
        mount "$BOOT_PART" /mnt/boot/efi
    else
        read -p "$(_ "Enter BOOT partition: ")" BOOT_PART
        echo "$(_ "Formatting BOOT...")"
        local BOOT_PART="/dev/$BOOT_PART"
        mount "$BOOT_PART" /mnt/boot
    fi

    local OLD_OS_NAME="OldOS"
    if [ -f /mnt/etc/os-release ]; then
        source /mnt/etc/os-release || source /mnt/usr/lib/os-release
        local OLD_OS_NAME="${NAME:-$ID}"
        local OLD_OS_NAME="${OLD_OS_NAME// /_}"
    fi

    mkdir -p /mnt/old.os/home_backup/

    for old_user in /mnt/home/*/; do
        [ -d "$old_user" ] || continue
        local user=$(basename "$old_user")
        local backup_path="/mnt/old.os/home_backup/$user"

        rsync -av "$old_user" "$backup_path/" \
            --exclude='.*cache*' --exclude='.*history' --exclude='.ssh' \
            --exclude='.gnupg' --exclude='.local/share/keyrings' \
            --exclude='.mozilla/firefox/*/logins.json' --exclude='*.iso' \
            --exclude='*.img' --exclude='Downloads/' --exclude='.local/share/Trash/'

        printf "$(_ "Saved user %s to %s")\n" "$user" "$backup_path"
        rm -rf "$old_user"
    done

    rm -rf /mnt/home 2>/dev/null || true

    local EXCLUDE="--exclude=/mnt/*/.cache --exclude=/mnt/var/cache --exclude=/mnt/run --exclude=/mnt/tmp --exclude=/mnt/var/run --exclude=/mnt/var/lock --exclude=/mnt/swapfile --exclude=/mnt/lost+found --exclude=/mnt/.snapshots --exclude=/mnt/srv --exclude=/mnt/mnt --exclude=/mnt/media --exclude=/mnt/home --exclude=/mnt/swap.img --exclude=/mnt/.Trash* --exclude=/mnt/*/backup*"

    mkdir -p /mnt/old.os

    old_os_back=$(dialog --title "$(_ "Backup Mode")" --menu "$(_ "Select compression:")" 15 60 3 \
        1 "tar.xz ($(_ "Best/Slow"))" \
        2 "tar.zst ($(_ "Balance"))" \
        3 "tar.gz ($(_ "Fast/Weak"))" 3>&1 1>&2 2>&3 3>&-)

    case "$old_os_back" in
        1) tar $EXCLUDE -c /mnt | xz -9 > "/mnt/old.os/${OLD_OS_NAME}_backup.tar.xz" ;;
        2) tar $EXCLUDE -c /mnt | zstd -19 -T0 > "/mnt/old.os/${OLD_OS_NAME}_backup.tar.zst" ;;
        3) tar $EXCLUDE -c /mnt | pigz -c > "/mnt/old.os/${OLD_OS_NAME}_backup.tar.gz" ;;
    esac

    local TARGET="/mnt"
    if ! mountpoint -q "$TARGET"; then
        echo "$(_ "Target not mounted. Exit.")"
        exit 1
    fi

    find "$TARGET" -maxdepth 1 -mindepth 1 ! -name 'old.os' ! -name 'boot' -exec rm -rf {} +
}

auto_partition() {
    echo "$(_ "Auto Partitioning...")"
    DISK_SIZE=$(fdisk -l "$DISK" | grep "Disk $DISK" | awk '{print int($3)}')

    if [ "$DISK_SIZE" -lt 10 ]; then
        echo "$(_ "Disk too small!")"
        exit 1
    fi

    sgdisk -Z "$DISK" 2>/dev/null || dd if=/dev/zero of="$DISK" bs=1M count=100

    if [ $UEFI_MODE -eq 1 ]; then
        parted -s "$DISK" mklabel gpt
        parted -s "$DISK" mkpart primary fat32 1MiB 513MiB
        parted -s "$DISK" set 1 esp on
        export BOOT_PART="${DISK}1"
    else
        parted -s "$DISK" mklabel msdos
        parted -s "$DISK" mkpart primary 1MiB 513MiB
        parted -s "$DISK" set 1 boot on
        export BOOT_PART="${DISK}1"
    fi

    parted -s "$DISK" mkpart primary 513MiB 4.5GiB
    export SWAP_PART="${DISK}2"
    parted -s "$DISK" mkpart primary 4.5GiB 100%
    export ROOT_PART="${DISK}3"

    partprobe "$DISK"
    sleep 2
}

format_partitions() {
    echo "$(_ "Formatting...")"
    [ $UEFI_MODE -eq 1 ] && mkfs.fat -F32 "$BOOT_PART" || mkfs.ext2 -F "$BOOT_PART"

    mkfs.ext4 -F "$ROOT_PART"
    mkswap "$SWAP_PART"
    swapon "$SWAP_PART"
}

mount_partitions() {
    echo "$(_ "Mounting...")"
    mount "$ROOT_PART" /mnt
    if [ $UEFI_MODE -eq 1 ]; then
        mkdir -p /mnt/boot/efi
        mount "$BOOT_PART" /mnt/boot/efi
    else
        mkdir -p /mnt/boot
        mount "$BOOT_PART" /mnt/boot
    fi
}

# MAIN MENU
MODE=$(dialog --title "$(_ "Partitioning")" --menu "$(_ "Select mode:")" 15 60 4 \
    1 "$(_ "Auto Mode")" \
    2 "$(_ "Manual Mode")" \
    3 "$(_ "OS Change (Beta)")" \
    4 "$(_ "Exit")" 3>&1 1>&2 2>&3 3>&-)

clear

case $MODE in
    1)
        auto_partition
        format_partitions
        mount_partitions
        ;;
    2)
        cfdisk "$DISK"
        read -p "$(_ "Enter ROOT partition: ")" ROOT_PART
        ROOT_PART="/dev/$ROOT_PART"

        luks=$(dialog --title "$(_ "Encryption")" --menu "$(_ "Encrypt root?")" 15 60 2 1 "$(_ "Yes")" 2 "$(_ "No")" 3>&1 1>&2 2>&3 3>&-)
        if [ "$luks" -eq 1 ]; then
            cryptsetup luksFormat --type luks2 "$ROOT_PART"
            cryptsetup luksOpen "$ROOT_PART" "QuasarRoot"
            ROOT_PART_FINAL="/dev/mapper/QuasarRoot"
            export LUKS_MODE=1
        else
            ROOT_PART_FINAL="$ROOT_PART"
        fi

        fs=$(dialog --title "$(_ "Filesystem")" --menu "$(_ "Choose FS:")" 15 60 3 1 "EXT4" 2 "BTRFS" 3 "XFS" 3>&1 1>&2 2>&3 3>&-)
        case $fs in
            1) mkfs.ext4 -F "$ROOT_PART_FINAL" ;;
            2) mkfs.btrfs -f "$ROOT_PART_FINAL" ;;
            3) mkfs.xfs -f "$ROOT_PART_FINAL" ;;
        esac

        mount "$ROOT_PART_FINAL" /mnt

        if [ $UEFI_MODE -eq 1 ]; then
            read -p "$(_ "Enter EFI partition: ")" BOOT_PART
            BOOT_PART="/dev/$BOOT_PART"
            mkdir -p /mnt/boot/efi
            mkfs.fat -F32 "$BOOT_PART"
            mount "$BOOT_PART" /mnt/boot/efi
        else
            read -p "$(_ "Enter BOOT partition: ")" BOOT_PART
            BOOT_PART="/dev/$BOOT_PART"
            mkdir -p /mnt/boot
            mkfs.ext2 -F "$BOOT_PART"
            mount "$BOOT_PART" /mnt/boot
        fi
        ;;
    3) old_os_backap ;;
    4) exit 0 ;;
esac

echo "$(_ "Final Layout:")"
lsblk -o NAME,SIZE,FSTYPE,MOUNTPOINT "$DISK"
echo "$(_ "Partitioning complete!")"
