#!/usr/bin/env bash

# --- Локализация ---
export TEXTDOMAIN="installer"
export TEXTDOMAINDIR="/usr/local/sdk/global/locale"
_() { gettext -s "$1"; }

set_timezone() {
    local continent="$1"
    local zone_path="/mnt/usr/share/zoneinfo/$continent"

    # Проверка, существует ли директория
    if [ ! -d "$zone_path" ]; then
        echo "$(_ "Error: Continent directory not found:") $continent"
        exit 1
    fi

    # Получаем список регионов (только файлы, не папки)
    mapfile -t regions < <(find "$zone_path" -maxdepth 1 -type f -printf "%f\n" | sort)

    # Формируем массив для dialog
    local checklist_items=()
    for region in "${regions[@]}"; do
        checklist_items+=("$region" "$region" "off")
    done

    # Вызываем dialog
    selected=$(dialog --stdout --title "$(_ "Timezone Selection:") $continent" \
        --radiolist "$(_ "Select your city/region:")" 20 50 10 \
        "${checklist_items[@]}")

    if [ -n "$selected" ]; then
        clear
        # Удаляем старую ссылку, если есть, и создаем новую
        rm -f /mnt/etc/localtime
        ln -s "/usr/share/zoneinfo/$continent/$selected" /mnt/etc/localtime
        echo "$(_ "Timezone set to:") $continent/$selected"
    else
        echo "$(_ "Selection cancelled.")"
    fi
}

# --- Обработка аргумента ---
case "$1" in
    Europe|Asia|America|Africa|Antarctica|Arctic|Atlantic|Australia|Brazil|Canada|Etc)
        set_timezone "$1"
        ;;
    US) # Исправляем алиас, так как в zoneinfo папка называется America
        set_timezone "America"
        ;;
    *)
        echo "$(_ "Region not supported or not found.")"
        exit 1
        ;;
esac
